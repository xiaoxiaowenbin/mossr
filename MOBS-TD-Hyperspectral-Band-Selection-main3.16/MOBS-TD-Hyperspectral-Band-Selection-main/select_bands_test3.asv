function selected_bands = select_bands_test3(x_pareto, f_pareto, num_bands, K, snr_vec)
    % x_pareto: [N x L^2] 档案中的解（拉直的W矩阵）
    % f_pareto: [N x 3] 对应的三个目标函数值
    % num_bands: L (波段总数)
    % K: 要选的波段数
    % snr_vec: [L x 1] 预计算好的信噪比
    
    num_solutions = size(x_pareto, 1);
    
    % 1. 筛选精英解 (取前 25% 的解，比例可调)
    % 假设 f3 (f_pareto(:,3)) 是你最看重的性能指标
    [~, sort_idx] = sort(f_pareto(:, 3), 'ascend');
    num_elite = max(1, round(num_solutions * 0.25));
    elite_indices = sort_idx(1:num_elite);
    
    % 2. 累积投票
    band_scores = zeros(num_bands, 1);
    for i = 1:num_elite
        % 提取当前解并还原为 L x L 矩阵
        W = reshape(x_pareto(elite_indices(i), :), num_bands, num_bands);
        % MOSSR 核心：计算每行的能量作为该波段的重要性权重
        % 并在投票时考虑该解本身的性能 (1/f)，性能越好权重越大
        fitness_weight = 1 / (f_pareto(elite_indices(i), 3) + eps);
        band_scores = band_scores + sum(W.^2, 2) * fitness_weight;
    end
    
    % 3. 动态噪声抑制 (SNR Masking)
    % 自动找出 SNR 极低的波段（如低于中位数的 60%）
    snr_threshold = median(snr_vec) * 0.6;
    noise_bands = find(snr_vec < snr_threshold);
    
    % 同时保留传感器边缘强制静默（保险做法）
    edge_bands = [1:3, (num_bands-2):num_bands];
    invalid_bands = unique([noise_bands; edge_bands']);

    band_scores(invalid_bands) = -inf; 
    
    % 4. 贪婪搜索与邻域抑制
    selected_bands = [];
    temp_scores = band_scores;
    % 动态计算抑制窗口大小：防止 K 过大时无波段可选
    exclusion_window = max(1, floor(num_bands / (K * 4))); 
   
    for k = 1:K
        [max_val, best_idx] = max(temp_scores);
        if max_val == -inf, break; end
        
        selected_bands = [selected_bands; best_idx];
        
        % 抑制邻域：将选中波段附近的权重设为极小值
        low_bound = max(1, best_idx - exclusion_window);
        up_bound = min(num_bands, best_idx + exclusion_window);
        temp_scores(low_bound:up_bound) = -inf;
    end
    
    % 5. 排序输出
    selected_bands = sort(selected_bands);
    
    % 兜底逻辑：如果选不够，从非噪声波段补齐
    if length(selected_bands) < K
        valid_pool = setdiff(1:num_bands, [selected_bands', invalid_bands']);
        n_need = K - length(selected_bands);
        if ~isempty(valid_pool)
            selected_bands = sort([selected_bands; valid_pool(1:min(n_need, length(valid_pool)))']);
        end
    end
end